{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and streak information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "streak": { "type": "number" },
        "lastPracticeDate": { "type": "string" },
        "totalTests": { "type": "number" }
      },
      "required": ["userId", "email", "createdAt", "streak", "totalTests"]
    },
    "TypingTestResult": {
      "title": "TypingTestResult",
      "description": "A single typing test result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "wpm": { "type": "number" },
        "accuracy": { "type": "number" },
        "testType": { "type": "string" },
        "duration": { "type": "number" },
        "mode": { "type": "string" },
        "mistypedKeys": { "type": "object" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "username", "wpm", "accuracy", "testType", "duration", "mode", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "typing_results/{resultId}": {
      "schema": { "$ref": "#/entities/TypingTestResult" },
      "description": "Individual typing test results and leaderboard entries"
    }
  }
}
